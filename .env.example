# Database (MySQL)
# Local dev: use your machine's DB, or point at the preview DB on the server (hostname/IP, not "localhost").
# URL-encode special characters in the password (e.g. & → %26).
# DATABASE_URL="mysql://crm-preview:YOUR_PASSWORD@your-server-host:3306/internship_crm_preview"
DATABASE_URL="mysql://user:password@localhost:3306/internship_crm"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-change-in-production"

# Email (SMTP) — crm.ersah.in (Plesk)
# Outgoing: crm.ersah.in, port 465 (SSL) — matches panel; smtp.crm.ersah.in may also work
# Incoming (not used by app): IMAP 993 (SSL), POP3 995 (SSL)
# If 465 fails, try 587 (STARTTLS) on the same host
SMTP_HOST="crm.ersah.in"
SMTP_PORT="465"
SMTP_USER="noreply@crm.ersah.in"
# Real password only in .env — never commit secrets to git
SMTP_PASS="your-smtp-password"
SMTP_FROM="noreply@crm.ersah.in"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# First admin (optional — used by: npx prisma db seed)
# SEED_ADMIN_EMAIL="admin@example.com"
# SEED_ADMIN_PASSWORD="ChangeMe123!"
# SEED_ADMIN_NAME="Admin"
