generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MENTOR
  MENTEE
}

enum MentorshipStatus {
  ACTIVE
  COMPLETED
}

enum InteractionType {
  Meeting
  Feedback
  Email
}

// Mentee'nin staj/işe alım sürecindeki granular aşaması (Excel status kolonunun karşılığı)
enum PipelineStatus {
  BASVURU_100 // 100 ilk temas
  ONAY_220 // 220 staj için onay bekliyor
  GORUSME_250 // 250 görüşülecek
  TANISTIRMA_270 // 270 tanıştırılacak
  STAJ_BASLAYACAK_300 // 300 staj başlayacak
  STAJ_DEVAM_450 // 450 staj devam ediyor
  YARIM_BIRAKTI_460 // 460 staj yarım bıraktı
  STAJ_BITTI_490 // 490 staj bitti
  IS_ARIYOR_500 // 500 iş arıyor
  ISE_ALINABILIR_600 // 600 işe alınabilir
  ISE_ALINDI_660 // 660 işe alındı
  IS_BULDU_700 // 700 iş buldu
  BASKA_YERDE_STAJ_800 // 800 başka yerde staj buldu
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password       String
  role           Role     @default(MENTEE)
  fullName       String
  phone          String?
  university     String?
  department     String?
  graduationYear Int?
  skills         Json     @default("[]")
  cvUrl          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  mentorRelations MentorshipRelation[] @relation("MentorRelations")
  menteeRelations MentorshipRelation[] @relation("MenteeRelations")
}

model Company {
  id           String   @id @default(cuid())
  name         String
  description  String?
  contactEmail String?
  industry     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  needs       CompanyNeed[]
  mentorships MentorshipRelation[]
}

model CompanyNeed {
  id        String @id @default(cuid())
  companyId String
  position  String
  count     Int
  period    String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model MentorshipRelation {
  id             String           @id @default(cuid())
  mentorId       String
  menteeId       String
  companyId      String?
  startDate      DateTime         @default(now())
  status         MentorshipStatus @default(ACTIVE)
  pipelineStatus PipelineStatus   @default(BASVURU_100)

  mentor       User             @relation("MentorRelations", fields: [mentorId], references: [id])
  mentee       User             @relation("MenteeRelations", fields: [menteeId], references: [id])
  company      Company?         @relation(fields: [companyId], references: [id])
  interactions InteractionLog[]
}

model InteractionLog {
  id         String          @id @default(cuid())
  relationId String
  date       DateTime
  notes      String
  type       InteractionType

  relation MentorshipRelation @relation(fields: [relationId], references: [id], onDelete: Cascade)
}

model InvitationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  role      Role
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime
}
